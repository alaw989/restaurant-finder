includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    level: 5
    paths:
        - app/
    # Exclude tests for now - we'll add them in a later spec
    excludePaths:
        - tests/
    # Baseline to absorb pre-existing findings - will be regenerated
    ignoreErrors:
        # Pre-existing baseline errors - will be regenerated via CI
        - '#Command "restaurants:ai-enrich" does not have option "all"#'
        - '#Access to an undefined property Illuminate\\Database\\Eloquent\\Model::\$#'
        - '#Parameter #3 \$cuisine of method App\\Services\\RestaurantEnrichmentService::enrichByCuisine\(\) expects App\\Models\\Cuisine#'
        - '#Using nullsafe method call on non-nullable type#'
        - '#Parameter #4 \$lastmod of method App\\Console\\Commands\\GenerateSitemap::urlNode\(\) expects#'
        - '#Parameter #1 \$user of class Illuminate\\Auth\\Events\\Verified constructor expects#'
        - '#Parameter #1 \$callback of method Illuminate\\Database\\Eloquent\\Collection#'
        - '#Call to an undefined method Illuminate\\Database\\Eloquent\\Relations\\BelongsToMany::syncWithoutDetachment\(\)#'
        - '#Anonymous function should return#'
        - '#Call to an undefined method#'
        - '#Variable \$updates in empty\(\) always exists and is not falsy#'
        - '#Variable \$aiMetadata on left side of \?\? is never defined#'
        - '#Constant App\\Services\\LiveSearchService::OSM_SOURCES is unused#'
        - '#Method App\\Services\\LiveSearchService::deduplicate\(\) is unused#'
        - '#Unsafe access to private constant App\\Services\\OverpassService::RADII through static::#'
        - '#Method App\\Services\\PopularityScoreService::rawValue\(\) is unused#'
        - '#Property App\\Services\\RestaurantEnrichmentService::\$aiEnrichment is never read#'
        - '#Variable \$reviewCount in isset\(\) always exists and is not nullable#'
        - '#Strict comparison using !== between array and null will always evaluate to true#'
        - '#Offset .cuisines. \(Illuminate\\Support\\Collection<int, array#'
        - '#Parameter #1 \$callback of method Illuminate\\Database\\Eloquent\\Collection#contains unresolvable type#'
        - '#Parameter #1 \$callback of method#'
