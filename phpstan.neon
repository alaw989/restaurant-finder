includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    level: 5
    paths:
        - app/
    # Exclude tests for now - we'll add them in a later spec
    excludePaths:
        - tests/
    # Generate a baseline on first run to absorb pre-existing findings
    baselineFile: phpstan-baseline.neon
    # Increase memory limit for large codebase analysis
    memoryLimit: 2G
