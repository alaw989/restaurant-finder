APP_NAME=iPop360
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# External API keys (optional - app works without any keys)
GOOGLE_PLACES_API_KEY=
OUTSCRAPER_API_KEY=
FOURSQUARE_API_KEY=
SERPAPI_API_KEY=
SOCRATA_APP_TOKEN=
SOCRATA_NYC_DATASET_ID=py6s-7cay
SOCRATA_SF_DATASET_ID=vw6y-z8j6
AI_API_KEY=
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.3-70b-versatile

# --- Ranking weights (optional). Defaults live in config/restaurant-finder.php.
# Free signals must stay meaningful (they renormalize over their active set).
RANK_WEIGHT_QUALITY=0.60
RANK_WEIGHT_PROXIMITY=0.20
RANK_WEIGHT_DATA_COMPLETENESS=0.05
RANK_WEIGHT_HAS_AWARD=0.15
# Paid bonus signals (no-op without keys, weight active only when a value exists)
RANK_WEIGHT_GOOGLE_RATING=0.03
RANK_WEIGHT_GOOGLE_REVIEW_COUNT=0.02
RANK_WEIGHT_POPULAR_TIMES=0
# Bayesian quality prior: reviews needed before rating is treated as credible
RANK_QUALITY_PRIOR=50
# Fallback credible-mean rating when no venue meets the prior threshold
RANK_QUALITY_MEAN_FALLBACK=4.0
# Proximity scale (km): at 1× scale (default 2km), a venue at 2km scores 0.5
RANK_PROXIMITY_SCALE_KM=2.0
# Log review-count normalization (denominator = max(collectionMax, floor), default when empty)
RANK_LOG_REVIEW_FLOOR=500
RANK_LOG_REVIEW_DEFAULT=5000
# Name-similarity threshold for matching Wikidata award records
RANK_AWARD_NAME_SIMILARITY=0.7

# --- Live search timeouts and caps (seconds, km, count) ---
LIVE_SEARCH_HTTP_TIMEOUT=8.0
LIVE_SEARCH_FOURSQUARE_TIMEOUT=8.0
LIVE_SEARCH_OVERPASS_TIMEOUT=10.0
LIVE_SEARCH_SOCRATA_TIMEOUT=8.0
LIVE_SEARCH_MAX_DISTANCE_KM=50.0
LIVE_SEARCH_MAX_RESULTS=30
LIVE_SEARCH_MIN_SCORE=0.0

# --- Dedup thresholds (km, percentage) ---
DEDUP_MATCH_RADIUS_KM=0.2
DEDUP_NAME_SIMILARITY_THRESHOLD=85.0

# --- DB enrichment caps (SerpApi quota protection) ---
ENRICH_PER_RUN_CAP=5
ENRICH_MONTHLY_BUDGET=40

# --- SerpApi cache and quota ---
SERPAPI_CACHE_TTL_HOURS=720
SERPAPI_FREE_QUOTA=50

# --- External API cache TTLs (hours) ---
# Other external sources — free/unlimited, shorter TTLs are fine
OUTSCRAPER_CACHE_TTL_HOURS=168
GOOGLE_CACHE_TTL_HOURS=24
OVERPASS_CACHE_TTL_HOURS=24
BIZDATA_CACHE_TTL_HOURS=24
FOURSQUARE_CACHE_TTL_HOURS=24
SOCRATA_CACHE_TTL_HOURS=24

# --- Preview snapshot TTL ---
PREVIEW_SNAPSHOT_DAYS=7

# --- Garbage name filters ---
GARBAGE_GENERIC_WORDS=diner restaurant cafe pizza bar grill bistro pub tavern eatery food kitchen cantina

# --- Cuisine filter source controls ---
# Sources that do NOT filter by cuisine (returns all nearby venues)
CUISINE_UNFILTERED_SOURCES=bizdata
# When true, scrutinize trusted sources (serpapi/overpass/foursquare) for off-cuisine rows
SCRUTINIZE_TRUSTED_SOURCES=true
# When true, drop rows whose Google place_types indicate non-restaurants
SCRUTINIZE_PLACE_TYPES=true

# Laravel Pulse (observability)
PULSE_ENABLED=true
PULSE_PATH=pulse
# spec-076: comma-separated allow-list of emails that may view /pulse in prod.
# Empty = no one (dashboard private). Needed because registration is open.
PULSE_ADMIN_EMAILS=
